{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edgedisk",
  "main": "src/index.ts",
  "keep_vars": true,
  "compatibility_date": "2026-03-18",
  "r2_buckets": [
    {
      "binding": "DISK",
      "bucket_name": "edgedisk"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SHARES",
      "id": "e213e68599fa4bb8ad703b14b1b4d923"
    }
  ],
  "vars": {
    "APP_NAME": "EdgeDisk",
    "MAX_LIST_KEYS": "1000"
  }
}
